{
  "configVersion": 2,
  "network": {
    "hostname": "esp32-s3-eth",
    "dhcp": true
  },
  "sensors": {
    "intervalMs": 5000,
    "resolutionBits": 12,
    "conversionTimeoutMs": 1000
  },
  "rest": {
    "enabled": true,
    "port": 80
  },
  "mqtt": {
    "enabled": true,
    "host": "192.168.10.202",
    "port": 1883,
    "user": "loxberry",
    "pass": "loxberrymqtt",
    "baseTopic": "device",
    "offlineBufferPerSensor": 20,
    "offlinePersistSdEnabled": true,
    "offlinePersistPath": "/mqtt_offline.jsonl",
    "offlinePersistMaxLines": 1000,
    "publishHealth": true,
    "healthIntervalMs": 15000,
    "reconnectMinMs": 1000,
    "reconnectMaxMs": 60000
  },
  "history": {
    "enabled": true,
    "path": "/history.jsonl",
    "flushIntervalMs": 2000,
    "retentionDays": 30
  },
  "logging": {
    "consoleLevel": "INFO",
    "sdLevel": "INFO",
    "sdEnabled": true,
    "rotateDaily": true,
    "retentionDays": 30
  },
  "metrics": {
    "enabled": true
  },
  "ota": {
    "enabled": true,
    "allowInsecureHttp": true,
    "allowDowngrade": false,
    "requireHashHeader": true,
    "healthConfirmMs": 30000,
    "requireNetworkForConfirm": true
  },
  "watchdog": {
    "enabled": true,
    "timeoutMs": 15000,
    "panicReset": true
  },
  "security": {
    "enabled": true,
    "restAuthMode": "anonymous",
    "allowAnonymousGet": true,
    "restAuthMode": "token",
    "restToken": "0U96ZKLNJzhLGrN9doxecGWiZYCRrlJa"
  }
}
