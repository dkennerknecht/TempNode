{
  "network": {
    "hostname": "esp32-s3-eth",
    "dhcp": true
  },
  "sensors": {
    "intervalMs": 5000,
    "resolutionBits": 12,
    "conversionTimeoutMs": 1000
  },
  "rest": {
    "enabled": true,
    "port": 80
  },
  "mqtt": {
    "enabled": true,
    "host": "192.168.1.10",
    "port": 1883,
    "user": "",
    "pass": "",
    "baseTopic": "device",
    "offlineBufferPerSensor": 20,
    "reconnectMinMs": 1000,
    "reconnectMaxMs": 60000
  },
  "history": {
    "enabled": true,
    "path": "/history.jsonl",
    "flushIntervalMs": 2000,
    "retentionDays": 30
  },
  "logging": {
    "consoleLevel": "INFO",
    "sdLevel": "INFO",
    "sdEnabled": true,
    "rotateDaily": true,
    "retentionDays": 30
  },
  "metrics": {
    "enabled": true
  },
  "ota": {
    "enabled": false,
    "allowInsecureHttp": false,
    "allowDowngrade": false,
    "requireHashHeader": true,
    "healthConfirmMs": 30000,
    "requireNetworkForConfirm": true
  },
  "watchdog": {
    "enabled": false,
    "timeoutMs": 15000,
    "panicReset": true
  },
  "security": {
    "enabled": false,
    "restUser": "api",
    "restPass": "CHANGE_ME_STRONG_PASSWORD",
    "restToken": ""
  }
}
