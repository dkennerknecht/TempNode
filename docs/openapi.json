{
  "openapi": "3.1.0",
  "info": {
    "title": "TempNode REST API",
    "version": "1.0.0",
    "description": "REST API for TempNode on ESP32-S3-ETH. Runtime auth behavior is controlled by security.restAuthMode (anonymous|token) and security.allowAnonymousGet.",
    "license": {
      "name": "UNLICENSED",
      "identifier": "UNLICENSED"
    }
  },
  "servers": [
    {
      "url": "http://{node_ip}",
      "description": "TempNode HTTP server",
      "variables": {
        "node_ip": {
          "default": "192.168.1.50"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Service and subsystem health information."
    },
    {
      "name": "sensors",
      "description": "Sensor readings and sensor runtime configuration."
    },
    {
      "name": "system",
      "description": "System runtime details and device diagnostics."
    },
    {
      "name": "metrics",
      "description": "Operational counters and runtime metrics."
    },
    {
      "name": "history",
      "description": "Tail access for persisted sensor history."
    },
    {
      "name": "config",
      "description": "Secure runtime configuration retrieval and update."
    },
    {
      "name": "ota",
      "description": "Firmware and filesystem upload endpoints for OTA updates."
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["health"],
        "operationId": "getHealth",
        "summary": "Detailed service health",
        "description": "Returns status and detailed subsystem checks (network, mqtt, sd, time, ota_state).",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/HealthResponse"}
              }
            }
          },
          "503": {
            "description": "Degraded",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/HealthResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/temps": {
      "get": {
        "tags": ["sensors"],
        "operationId": "getTemps",
        "summary": "Latest readings of all discovered sensors",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Array of latest temperatures",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/TempReading"}
                }
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/sensors": {
      "get": {
        "tags": ["sensors"],
        "operationId": "getSensors",
        "summary": "Sensor summary and latest values",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Sensor summary",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/SensorsSummaryResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/sensors/interval": {
      "get": {
        "tags": ["sensors"],
        "operationId": "getSensorInterval",
        "summary": "Read current sensor interval",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Current interval and latest readings",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/SensorsSummaryResponse"}
              }
            }
          },
          "500": {
            "description": "Sensors unavailable",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      },
      "post": {
        "tags": ["sensors"],
        "operationId": "setSensorIntervalPost",
        "summary": "Set sensor interval",
        "description": "Supports query parameter, form field, or JSON body with intervalMs. Applies interval at runtime and persists it to LittleFS; mirrors to SD when /config.json exists on SD.",
        "parameters": [
          {
            "name": "intervalMs",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "minimum": 1}
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/IntervalSetRequest"}
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "intervalMs": {"type": "integer", "minimum": 1}
                }
              }
            }
          }
        },
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Interval updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/IntervalSetResponse"}
              }
            }
          },
          "400": {
            "description": "Missing or invalid interval",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "500": {
            "description": "Interval changed at runtime but persistence failed",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/IntervalSetResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      },
      "put": {
        "tags": ["sensors"],
        "operationId": "setSensorIntervalPut",
        "summary": "Set sensor interval (semantic update)",
        "description": "Applies interval at runtime and persists it to LittleFS; mirrors to SD when /config.json exists on SD.",
        "parameters": [
          {
            "name": "intervalMs",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "minimum": 1}
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/IntervalSetRequest"}
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "intervalMs": {"type": "integer", "minimum": 1}
                }
              }
            }
          }
        },
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Interval updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/IntervalSetResponse"}
              }
            }
          },
          "400": {
            "description": "Missing or invalid interval",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "500": {
            "description": "Interval changed at runtime but persistence failed",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/IntervalSetResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/config": {
      "get": {
        "tags": ["config"],
        "operationId": "getConfigRedacted",
        "summary": "Get redacted runtime config",
        "description": "Returns current config with secrets redacted. This endpoint always requires Bearer token auth and token mode.",
        "security": [
          {"bearerAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Redacted config",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfigObject"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Token mode required"
          }
        }
      },
      "put": {
        "tags": ["config"],
        "operationId": "putConfig",
        "summary": "Safely patch runtime config",
        "description": "Merges provided patch into current config, validates, optionally dry-runs, persists to LittleFS, mirrors to SD when /config.json exists, and can reboot when requested and required.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/ConfigUpdateRequest"}
            }
          }
        },
        "security": [
          {"bearerAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Config update accepted",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfigUpdateResponse"}
              }
            }
          },
          "400": {
            "description": "Invalid patch or validation/persistence failed",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfigUpdateResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Token mode required"
          }
        }
      }
    },
    "/api/v1/system": {
      "get": {
        "tags": ["system"],
        "operationId": "getSystem",
        "summary": "System diagnostics",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "System information",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/SystemResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/metrics": {
      "get": {
        "tags": ["metrics"],
        "operationId": "getMetrics",
        "summary": "Runtime metrics and persisted counters",
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "Metrics payload",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MetricsResponse"}
              }
            }
          },
          "404": {
            "description": "Metrics disabled",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/history": {
      "get": {
        "tags": ["history"],
        "operationId": "getHistory",
        "summary": "Tail history entries",
        "parameters": [
          {
            "name": "sensor",
            "in": "query",
            "required": false,
            "schema": {"type": "string"},
            "description": "Optional sensor ID filter"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "minimum": 1, "maximum": 1000, "default": 100},
            "description": "Maximum number of entries"
          }
        ],
        "security": [
          {"bearerAuth": []},
          {"basicAuth": []}
        ],
        "responses": {
          "200": {
            "description": "History entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/HistoryEntry"}
                }
              }
            }
          },
          "404": {
            "description": "History disabled",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "503": {
            "description": "History unavailable",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ErrorResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/ota": {
      "post": {
        "tags": ["ota"],
        "operationId": "postOtaUpload",
        "summary": "Upload OTA firmware image",
        "description": "Endpoint is only active when OTA and security preconditions are fulfilled in runtime config.",
        "parameters": [
          {
            "name": "X-OTA-SHA256",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            },
            "description": "Recommended integrity header"
          },
          {
            "name": "X-OTA-MD5",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{32}$"
            },
            "description": "Legacy integrity header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["firmware"],
                "properties": {
                  "firmware": {
                    "type": "string",
                    "format": "binary",
                    "description": "Firmware .bin file"
                  }
                }
              }
            }
          }
        },
        "security": [
          {"bearerAuth": []}
        ],
        "responses": {
          "200": {
            "description": "OTA accepted, reboot pending",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/OtaSuccessResponse"}
              }
            }
          },
          "400": {
            "description": "Upload rejected",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/OtaErrorResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/v1/ota/fs": {
      "post": {
        "tags": ["ota"],
        "operationId": "postOtaFilesystemUpload",
        "summary": "Upload OTA LittleFS image",
        "description": "Uploads a LittleFS image (.bin) to the filesystem partition. Endpoint is active under the same OTA/security preconditions as firmware OTA.",
        "parameters": [
          {
            "name": "X-OTA-SHA256",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            },
            "description": "Recommended integrity header"
          },
          {
            "name": "X-OTA-MD5",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{32}$"
            },
            "description": "Legacy integrity header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["filesystem"],
                "properties": {
                  "filesystem": {
                    "type": "string",
                    "format": "binary",
                    "description": "LittleFS image .bin file"
                  }
                }
              }
            }
          }
        },
        "security": [
          {"bearerAuth": []}
        ],
        "responses": {
          "200": {
            "description": "LittleFS OTA accepted, reboot pending",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/OtaSuccessResponse"}
              }
            }
          },
          "400": {
            "description": "Upload rejected",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/OtaErrorResponse"}
              }
            }
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "token"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {"type": "string"}
        },
        "additionalProperties": true
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "timestamp", "checks"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "degraded"]
          },
          "timestamp": {"type": "integer"},
          "checks": {
            "type": "object",
            "required": ["network", "mqtt", "sd", "time", "ota_state"],
            "properties": {
              "network": {"$ref": "#/components/schemas/HealthNetwork"},
              "mqtt": {"$ref": "#/components/schemas/HealthMqtt"},
              "sd": {"$ref": "#/components/schemas/HealthSd"},
              "time": {"$ref": "#/components/schemas/HealthTime"},
              "ota_state": {"$ref": "#/components/schemas/HealthOtaState"}
            }
          }
        }
      },
      "HealthNetwork": {
        "type": "object",
        "required": ["ok", "up", "link", "ip", "mac"],
        "properties": {
          "ok": {"type": "boolean"},
          "up": {"type": "boolean"},
          "link": {"type": "boolean"},
          "ip": {"type": "string"},
          "mac": {"type": "string"}
        }
      },
      "HealthMqtt": {
        "type": "object",
        "required": [
          "required",
          "enabled",
          "connected",
          "ok",
          "host",
          "port",
          "user",
          "connectAttempts",
          "diagLastUptimeMs",
          "resolveOk",
          "resolvedIp",
          "pingOk",
          "pingMs",
          "tcpProbePort",
          "tcpProbeOpen",
          "altPortChecked",
          "altPort",
          "altPortOpen",
          "offlineSdEnabled",
          "offlineSdQueued",
          "offlineSdDropped"
        ],
        "properties": {
          "required": {"type": "boolean"},
          "enabled": {"type": "boolean"},
          "connected": {"type": "boolean"},
          "ok": {"type": "boolean"},
          "host": {"type": "string"},
          "port": {"type": "integer"},
          "user": {"type": "string"},
          "connectAttempts": {"type": "integer"},
          "diagLastUptimeMs": {"type": "integer"},
          "resolveOk": {"type": "boolean"},
          "resolvedIp": {"type": "string"},
          "pingOk": {"type": "boolean"},
          "pingMs": {"type": "integer"},
          "tcpProbePort": {"type": "integer"},
          "tcpProbeOpen": {"type": "boolean"},
          "altPortChecked": {"type": "boolean"},
          "altPort": {"type": "integer"},
          "altPortOpen": {"type": "boolean"},
          "offlineSdEnabled": {"type": "boolean"},
          "offlineSdQueued": {"type": "integer"},
          "offlineSdDropped": {"type": "integer"}
        }
      },
      "HealthSd": {
        "type": "object",
        "required": [
          "required",
          "available",
          "ok",
          "sdMountFails",
          "sdWriteFails",
          "diskSizeBytes",
          "diskUsedBytes",
          "diskFreeBytes",
          "usagePercent",
          "capacityKnown"
        ],
        "properties": {
          "required": {"type": "boolean"},
          "available": {"type": "boolean"},
          "ok": {"type": "boolean"},
          "sdMountFails": {"type": "integer"},
          "sdWriteFails": {"type": "integer"},
          "diskSizeBytes": {"type": "integer"},
          "diskUsedBytes": {"type": "integer"},
          "diskFreeBytes": {"type": "integer"},
          "usagePercent": {"type": "number"},
          "capacityKnown": {"type": "boolean"}
        }
      },
      "HealthTime": {
        "type": "object",
        "required": ["valid", "source", "stale", "ok", "lastNtpSyncUptimeMs", "ntpSyncFails"],
        "properties": {
          "valid": {"type": "boolean"},
          "source": {"type": "string", "enum": ["NTP", "UPTIME"]},
          "stale": {"type": "boolean"},
          "ok": {"type": "boolean"},
          "lastNtpSyncUptimeMs": {"type": "integer"},
          "ntpSyncFails": {"type": "integer"}
        }
      },
      "HealthOtaState": {
        "type": "object",
        "required": [
          "enabled",
          "endpointActive",
          "pendingVerify",
          "requireHashHeader",
          "allowDowngrade",
          "healthConfirmMs",
          "ok",
          "imageStateKnown",
          "imageState"
        ],
        "properties": {
          "enabled": {"type": "boolean"},
          "endpointActive": {"type": "boolean"},
          "pendingVerify": {"type": "boolean"},
          "requireHashHeader": {"type": "boolean"},
          "allowDowngrade": {"type": "boolean"},
          "healthConfirmMs": {"type": "integer"},
          "ok": {"type": "boolean"},
          "imageStateKnown": {"type": "boolean"},
          "imageState": {"type": "string"}
        }
      },
      "TempReading": {
        "type": "object",
        "required": ["sensorId", "tempC", "status", "timestamp", "timeValid", "timeSource"],
        "properties": {
          "sensorId": {"type": "string"},
          "tempC": {"type": "number"},
          "status": {"type": "integer"},
          "timestamp": {"type": "integer"},
          "timeValid": {"type": "boolean"},
          "timeSource": {"type": "string", "enum": ["NTP", "UPTIME"]}
        }
      },
      "SensorSummaryEntry": {
        "type": "object",
        "required": ["id", "status", "timestampMs"],
        "properties": {
          "id": {"type": "string"},
          "tempC": {
            "oneOf": [
              {"type": "number"},
              {"type": "null"}
            ]
          },
          "status": {"type": "integer"},
          "timestampMs": {"type": "integer"}
        }
      },
      "SensorsSummaryResponse": {
        "type": "object",
        "required": ["intervalMs", "sensors"],
        "properties": {
          "intervalMs": {"type": "integer"},
          "sensors": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/SensorSummaryEntry"}
          }
        }
      },
      "IntervalSetRequest": {
        "type": "object",
        "properties": {
          "intervalMs": {"type": "integer", "minimum": 1}
        }
      },
      "IntervalSetResponse": {
        "type": "object",
        "required": ["intervalMs", "ok"],
        "properties": {
          "intervalMs": {"type": "integer"},
          "ok": {"type": "boolean"},
          "persisted": {"type": "boolean"},
          "savedToLittleFs": {"type": "boolean"},
          "savedToSd": {"type": "boolean"},
          "message": {"type": "string"}
        }
      },
      "ConfigObject": {
        "type": "object",
        "additionalProperties": true
      },
      "ConfigUpdateRequest": {
        "type": "object",
        "properties": {
          "dryRun": {"type": "boolean", "default": false},
          "restart": {"type": "boolean", "default": false},
          "config": {
            "type": "object",
            "description": "Partial config object to merge into current runtime config.",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ConfigUpdateResponse": {
        "type": "object",
        "required": ["ok", "dryRun", "changed", "restartRequested", "restartRequired", "persisted", "savedToLittleFs", "savedToSd", "reboot"],
        "properties": {
          "ok": {"type": "boolean"},
          "dryRun": {"type": "boolean"},
          "changed": {"type": "boolean"},
          "restartRequested": {"type": "boolean"},
          "restartRequired": {"type": "boolean"},
          "persisted": {"type": "boolean"},
          "savedToLittleFs": {"type": "boolean"},
          "savedToSd": {"type": "boolean"},
          "reboot": {"type": "boolean"},
          "message": {"type": "string"}
        }
      },
      "SystemResponse": {
        "type": "object",
        "required": [
          "timestamp",
          "timeValid",
          "timeSource",
          "uptimeMs",
          "heap",
          "chipModel",
          "chipRev",
          "sdk",
          "ip",
          "link",
          "mac",
          "resetReason",
          "bootCount"
        ],
        "properties": {
          "timestamp": {"type": "integer"},
          "timeValid": {"type": "boolean"},
          "timeSource": {"type": "string", "enum": ["NTP", "UPTIME"]},
          "uptimeMs": {"type": "integer"},
          "heap": {"type": "integer"},
          "chipModel": {"type": "string"},
          "chipRev": {"type": "integer"},
          "sdk": {"type": "string"},
          "ip": {"type": "string"},
          "link": {"type": "boolean"},
          "mac": {"type": "string"},
          "resetReason": {"type": "string"},
          "bootCount": {"type": "integer"}
        }
      },
      "MetricsStats": {
        "type": "object",
        "required": ["sdMountFails", "sdWriteFails", "mqttReconnects", "sensorReadErrors", "ntpSyncFails"],
        "properties": {
          "sdMountFails": {"type": "integer"},
          "sdWriteFails": {"type": "integer"},
          "mqttReconnects": {"type": "integer"},
          "sensorReadErrors": {"type": "integer"},
          "ntpSyncFails": {"type": "integer"}
        }
      },
      "MetricsResponse": {
        "type": "object",
        "required": ["heap", "uptimeMs", "link", "ip", "mqttConnected", "logQueueDepth", "logDrops", "stats"],
        "properties": {
          "heap": {"type": "integer"},
          "uptimeMs": {"type": "integer"},
          "link": {"type": "boolean"},
          "ip": {"type": "string"},
          "mqttConnected": {"type": "boolean"},
          "logQueueDepth": {"type": "integer"},
          "logDrops": {"type": "integer"},
          "stats": {"$ref": "#/components/schemas/MetricsStats"}
        }
      },
      "HistoryEntry": {
        "type": "object",
        "required": ["timestamp", "sensorId", "tempC", "status", "timeSource"],
        "properties": {
          "timestamp": {"type": "integer"},
          "sensorId": {"type": "string"},
          "tempC": {"type": "number"},
          "status": {"type": "integer"},
          "timeSource": {"type": "integer"}
        },
        "additionalProperties": true
      },
      "OtaSuccessResponse": {
        "type": "object",
        "required": ["status", "reboot"],
        "properties": {
          "status": {"type": "string", "enum": ["ok"]},
          "reboot": {"type": "boolean"}
        }
      },
      "OtaErrorResponse": {
        "type": "object",
        "required": ["status", "message"],
        "properties": {
          "status": {"type": "string", "enum": ["error"]},
          "message": {"type": "string"}
        }
      }
    }
  }
}
